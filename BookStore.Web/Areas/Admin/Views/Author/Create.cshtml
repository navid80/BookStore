@model BookStore.Application.DTOs.CreateAuthorDto

@{
    ViewData["Title"] = "افزودن نویسنده";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <h4 class="mb-0"><i class="fa-solid fa-pen-nib me-2"></i> افزودن نویسنده جدید</h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fa-solid fa-arrow-right me-1"></i> بازگشت به لیست</a>
</div>

<div class="table-card" style="max-width:600px">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label asp-for="FullName" class="form-label fw-semibold">نام کامل نویسنده</label>
            <input asp-for="FullName" class="form-control" placeholder="مثال: صادق هدایت" />
            <span asp-validation-for="FullName" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Slug" class="form-label fw-semibold">Slug</label>
            <input asp-for="Slug" class="form-control" placeholder="مثال: sadegh-hedayat" dir="ltr" />
            <div class="form-text">اسلاگ باید با حروف لاتین کوچک و خط تیره باشد.</div>
            <span asp-validation-for="Slug" class="text-danger small"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">ذخیره</button>
            <a asp-action="Index" class="btn btn-outline-secondary">انصراف</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
