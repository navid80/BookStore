@model IEnumerable<BookStore.Application.DTOs.KeywordDetailsDto>

@{
    ViewData["Title"] = "کلیدواژه‌ها";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <h4 class="mb-0"><i class="fa-solid fa-tags me-2"></i> مدیریت کلیدواژه‌ها</h4>
    <a asp-action="Create" class="btn btn-primary btn-sm">
        + افزودن کلیدواژه جدید
    </a>
</div>

<form asp-action="FilterKeywords" method="get">
    <div class="search-bar my-3">
        <div class="input-group input-group-sm" style="height: 40px">
                <span class="input-group-text bg-white"><i class="fa-solid fa-magnifying-glass"></i></span>
                <input name="search" type="text" id="keywordSearchInput" class="form-control"
                    placeholder="جستجوی کلیدواژه‌..." />
        </div>
    </div>
</form>

<div class="table-card">
    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <div style="font-size:3rem"><i class="fa-solid fa-tags me-2"></i></div>
            <p class="mt-2">هیچ کلیدواژه‌ای ثبت نشده است.</p>
            <a asp-action="Create" class="btn btn-outline-primary btn-sm">اولین کلیدواژه را اضافه کنید</a>
        </div>
    }
    else
    {
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width:60px">#</th>
                    <th>کلیدواژه</th>
                    <th style="width:130px" class="text-end">عملیات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-muted">@item.Id</td>
                        <td>
                            <span class="badge bg-light text-dark border" style="font-size:.85rem; padding:5px 10px;">
                                @item.Word
                            </span>
                        </td>
                        <td class="text-end">
                            <div class="d-flex gap-2 justify-content-center">
                                <a asp-action="Update" asp-route-id="@item.Id"
                                class="btn btn-sm btn-outline-secondary me-1"><i class="fa-solid fa-pen-to-square me-1"></i> ویرایش</a>
                                <a asp-action="Delete" asp-route-id="@item.Id"
                                class="btn btn-sm btn-outline-danger"
                                onclick="return confirm('آیا از حذف این کلیدواژه اطمینان دارید؟')"><i class="fa-solid fa-trash me-1"></i> حذف</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
