@model BookStore.Application.DTOs.UpdateKeywordDto

@{
    ViewData["Title"] = "ویرایش کلیدواژه";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <h4 class="mb-0">✏️ ویرایش کلیدواژه</h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← بازگشت به لیست</a>
</div>

<div class="table-card" style="max-width:500px">
    <form asp-action="Update" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />

        <div class="mb-4">
            <label asp-for="Word" class="form-label fw-semibold">کلیدواژه</label>
            <input asp-for="Word" class="form-control" />
            <span asp-validation-for="Word" class="text-danger small"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">ذخیره تغییرات</button>
            <a asp-action="Index" class="btn btn-outline-secondary">انصراف</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
