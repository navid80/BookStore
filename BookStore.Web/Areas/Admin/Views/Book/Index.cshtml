@model IEnumerable<BookStore.Application.DTOs.BookListItemDto>

@{
    ViewData["Title"] = "مدیریت کتاب‌ها";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <h4 class="mb-0"><i class="fa-solid fa-book me-2"></i> مدیریت کتاب‌ها</h4>
    <a asp-action="Create" class="btn btn-primary btn-sm">+ افزودن کتاب جدید</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form asp-action="FilterBooks" method="get">
    <div class="search-bar my-3">
        <div class="input-group input-group-sm" style="height: 40px">
            <span class="input-group-text bg-white"><i class="fa-solid fa-magnifying-glass"></i></span>
            <input name="search" type="text" id="bookSearchInput" class="form-control"
                placeholder="جستجوی کتاب..." />
        </div>
    </div>
</form>

<div class="table-card">
    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <div style="font-size:3rem"><i class="fa-solid fa-book me-2"></i></div>
            <p class="mt-2">هیچ کتابی ثبت نشده است.</p>
            <a asp-action="Create" class="btn btn-outline-primary btn-sm">اولین کتاب را اضافه کنید</a>
        </div>
    }
    else
    {
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width:50px">#</th>
                    <th>عنوان کتاب</th>
                    <th>دسته‌بندی</th>
                    <th>نویسنده(ها)</th>
                    <th>سال</th>
                    <th style="width:80px">وضعیت</th>
                    <th style="width:140px" class="text-end">عملیات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var book in Model)
                {
                    <tr>
                        <td class="text-muted">@book.Id</td>
                        <td>
                            <strong>@book.Title</strong>
                            <div><span class="badge-slug">@book.Slug</span></div>
                        </td>
                        <td><span class="badge bg-light text-dark border">@book.CategoryName</span></td>
                        <td class="text-muted small">@string.Join("، ", book.AuthorNames)</td>
                        <td class="text-muted">@book.PublishedYear</td>
                        <td>
                            @if (book.IsFree)
                            {
                                <span class="badge bg-success">رایگان</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">غیررایگان</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="d-flex gap-2 justify-content-center">
                                <a asp-action="Update" asp-route-id="@book.Id"
                                class="btn btn-sm btn-outline-secondary me-1"><i class="fa-solid fa-pen-to-square me-1"></i> ویرایش</a>
                                <a asp-action="Delete" asp-route-id="@book.Id"
                                class="btn btn-sm btn-outline-danger"
                                onclick="return confirm('آیا از حذف این کتاب اطمینان دارید؟')"><i class="fa-solid fa-trash me-1"></i> حذف</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
