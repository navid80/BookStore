@model BookStore.Application.DTOs.CreateBookDto

@{
    ViewData["Title"] = "افزودن کتاب";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";

    var authors = ViewBag.Authors as IEnumerable<BookStore.Application.DTOs.AuthorDetailsDto>;
    var keywords = ViewBag.Keywords as IEnumerable<BookStore.Application.DTOs.KeywordDetailsDto>;
    var allBooks = ViewBag.AllBooks as IEnumerable<BookStore.Application.DTOs.BookListItemDto>;
    var selectedAuthorIds = ViewBag.SelectedAuthorIds as List<int> ?? new List<int>();
    var selectedKeywordIds = ViewBag.SelectedKeywordIds as List<int> ?? new List<int>();
    var selectedRelatedIds = ViewBag.SelectedRelatedBookIds as List<int> ?? new List<int>();
}

<div class="page-header">
    <h4 class="mb-0"><i class="fa-solid fa-book-open me-2"></i> افزودن کتاب جدید</h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fa-solid fa-arrow-right me-1"></i> بازگشت به لیست</a>
</div>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <div class="row g-4">

        <!-- ستون چپ: اطلاعات اصلی -->
        <div class="col-md-8">
            <div class="table-card">
                <h6 class="fw-bold mb-3 text-muted">اطلاعات اصلی</h6>

                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="Title" class="form-label fw-semibold">عنوان کتاب</label>
                        <input asp-for="Title" class="form-control" placeholder="عنوان کتاب را وارد کنید" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Slug" class="form-label fw-semibold">Slug</label>
                        <input asp-for="Slug" class="form-control" placeholder="book-title-here" dir="ltr" />
                        <span asp-validation-for="Slug" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Description" class="form-label fw-semibold">توضیحات</label>
                        <textarea asp-for="Description" class="form-control" rows="4"
                                  placeholder="توضیح مختصری درباره کتاب..."></textarea>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="CategoryId" class="form-label fw-semibold">دسته‌بندی</label>
                        <select asp-for="CategoryId" asp-items="ViewBag.Categories"
                                class="form-select">
                            <option value="">انتخاب کنید...</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="PublishedYear" class="form-label fw-semibold">سال انتشار</label>
                        <input asp-for="PublishedYear" type="number" class="form-control"
                               placeholder="1400" min="1300" max="1500" />
                        <span asp-validation-for="PublishedYear" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="PageCount" class="form-label fw-semibold">تعداد صفحات</label>
                        <input asp-for="PageCount" type="number" class="form-control"
                               placeholder="250" min="1" />
                        <span asp-validation-for="PageCount" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="ISBN" class="form-label fw-semibold">ISBN</label>
                        <input asp-for="ISBN" class="form-control" placeholder="978-xxxxxxxxxx" dir="ltr" />
                    </div>

                    <div class="col-md-3 d-flex align-items-end">
                        <div class="form-check mb-2">
                            <input asp-for="IsFree" class="form-check-input" type="checkbox" />
                            <label asp-for="IsFree" class="form-check-label">رایگان</label>
                        </div>
                    </div>

                    <div class="col-md-3 d-flex align-items-end">
                        <div class="form-check mb-2">
                            <input asp-for="IsPublished" class="form-check-input" type="checkbox" />
                            <label asp-for="IsPublished" class="form-check-label">منتشر شده</label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- فایل‌ها -->
            <div class="table-card mt-4">
                <h6 class="fw-bold mb-3 text-muted">فایل‌ها</h6>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="PdfFile" class="form-label fw-semibold">فایل PDF کتاب</label>
                        <input asp-for="PdfFile" type="file" class="form-control" accept=".pdf" />
                        <div class="form-text">فرمت مجاز: PDF</div>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="CoverImage" class="form-label fw-semibold">تصویر جلد</label>
                        <input asp-for="CoverImage" type="file" class="form-control"
                               accept=".jpg,.jpeg,.png,.webp" />
                        <div class="form-text">فرمت‌های مجاز: JPG, PNG, WEBP</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ستون راست: نویسندگان، کلیدواژه‌ها، کتاب‌های مرتبط -->
        <div class="col-md-4">

            <!-- نویسندگان -->
            <div class="table-card">
                <h6 class="fw-bold mb-3 text-muted">نویسندگان</h6>
                @if (authors != null && authors.Any())
                {
                    <div style="max-height:200px; overflow-y:auto;">
                        @foreach (var author in authors)
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox"
                                       name="AuthorIds" value="@author.Id"
                                       id="author_@author.Id"
                                       @(selectedAuthorIds.Contains(author.Id) ? "checked" : "") />
                                <label class="form-check-label" for="author_@author.Id">
                                    @author.FullName
                                </label>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted small">ابتدا نویسنده اضافه کنید.</p>
                }
            </div>

            <!-- کلیدواژه‌ها -->
            <div class="table-card mt-3">
                <h6 class="fw-bold mb-3 text-muted">کلیدواژه‌ها</h6>
                @if (keywords != null && keywords.Any())
                {
                    <div style="max-height:160px; overflow-y:auto;">
                        @foreach (var keyword in keywords)
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox"
                                       name="KeywordIds" value="@keyword.Id"
                                       id="keyword_@keyword.Id"
                                       @(selectedKeywordIds.Contains(keyword.Id) ? "checked" : "") />
                                <label class="form-check-label" for="keyword_@keyword.Id">
                                    @keyword.Word
                                </label>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted small">ابتدا کلیدواژه اضافه کنید.</p>
                }
            </div>

            <!-- کتاب‌های مرتبط -->
            <div class="table-card mt-3">
                <h6 class="fw-bold mb-3 text-muted">کتاب‌های مرتبط</h6>
                @if (allBooks != null && allBooks.Any())
                {
                    <div style="max-height:160px; overflow-y:auto;">
                        @foreach (var book in allBooks)
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox"
                                       name="RelatedBookIds" value="@book.Id"
                                       id="related_@book.Id"
                                       @(selectedRelatedIds.Contains(book.Id) ? "checked" : "") />
                                <label class="form-check-label small" for="related_@book.Id">
                                    @book.Title
                                </label>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted small">کتابی موجود نیست.</p>
                }
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-primary px-4">ذخیره کتاب</button>
        <a asp-action="Index" class="btn btn-outline-secondary">انصراف</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
