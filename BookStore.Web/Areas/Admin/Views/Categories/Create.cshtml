@model BookStore.Application.DTOs.CreateCategoryDto

@{
    ViewData["Title"] = "افزودن دسته‌بندی";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <h4 class="mb-0">🗂️ افزودن دسته‌بندی جدید</h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← بازگشت به لیست</a>
</div>

<div class="table-card" style="max-width:600px">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label asp-for="Name" class="form-label fw-semibold">نام دسته‌بندی</label>
            <input asp-for="Name" class="form-control" placeholder="مثال: رمان، علمی-تخیلی" />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Slug" class="form-label fw-semibold">Slug</label>
            <input asp-for="Slug" class="form-control" placeholder="مثال: roman" dir="ltr" />
            <div class="form-text">اسلاگ باید با حروف لاتین کوچک و بدون فاصله باشد.</div>
            <span asp-validation-for="Slug" class="text-danger small"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">ذخیره</button>
            <a asp-action="Index" class="btn btn-outline-secondary">انصراف</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
