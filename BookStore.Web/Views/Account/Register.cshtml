@model BookStore.Web.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "ثبت‌نام";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div style="background:#fff; border-radius:12px; border:1px solid #e2e8f0; padding:2rem;">
            <h4 class="fw-bold mb-4 text-center">ثبت‌نام</h4>

            <form asp-action="Register" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold">ایمیل</label>
                    <input asp-for="Email" class="form-control" placeholder="example@email.com" dir="ltr" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-semibold">رمز عبور</label>
                    <input asp-for="Password" type="password" class="form-control" dir="ltr" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label fw-semibold">تکرار رمز عبور</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" dir="ltr" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100">ثبت‌نام</button>

                <div class="text-center mt-3">
                    <span class="text-muted small">حساب دارید؟</span>
                    <a asp-action="Login" class="small">وارد شوید</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}