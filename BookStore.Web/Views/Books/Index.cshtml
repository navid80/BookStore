@model BookStore.Application.DTOs.PagedResult<BookStore.Application.DTOs.BookListItemDto>

@{
    ViewData["Title"] = "همه کتاب‌ها";
    var categories = ViewBag.Categories as IEnumerable<BookStore.Application.DTOs.CategoryDetailsDto> ?? Enumerable.Empty<BookStore.Application.DTOs.CategoryDetailsDto>();
    var authors = ViewBag.Authors as IEnumerable<BookStore.Application.DTOs.AuthorDetailsDto> ?? Enumerable.Empty<BookStore.Application.DTOs.AuthorDetailsDto>();
    var filter = ViewBag.Filter as BookStore.Application.DTOs.BookFilterDto ?? new BookStore.Application.DTOs.BookFilterDto();

    string BuildUrl(int page, string? cat = null, string? author = null) {
        var q = new System.Collections.Specialized.NameValueCollection();
        if (!string.IsNullOrEmpty(filter.SearchTerm)) q["SearchTerm"] = filter.SearchTerm;
        q["Page"] = page.ToString();
        if (cat != null) q["CategorySlug"] = cat;
        else if (!string.IsNullOrEmpty(filter.CategorySlug)) q["CategorySlug"] = filter.CategorySlug;
        if (author != null) q["AuthorSlug"] = author;
        else if (!string.IsNullOrEmpty(filter.AuthorSlug)) q["AuthorSlug"] = filter.AuthorSlug;
        var parts = new List<string>();
        foreach (string key in q) parts.Add($"{key}={Uri.EscapeDataString(q[key]!)}");
        return "/Books?" + string.Join("&", parts);
    }
}

<div class="row g-4">

    <!-- ── Sidebar ── -->
    <div class="col-md-3 col-lg-2">
        <div class="filter-sidebar">

            <h6>🗂️ دسته‌بندی‌ها</h6>
            <a href="@BuildUrl(1, "")" class="filter-link @(string.IsNullOrEmpty(filter.CategorySlug) ? "active" : "")">همه دسته‌ها</a>
            @foreach (var cat in categories)
            {
                <a href="@BuildUrl(1, cat.Slug)" class="filter-link @(filter.CategorySlug == cat.Slug ? "active" : "")">
                    @cat.Name
                </a>
            }

            @if (authors.Any())
            {
                <h6 class="mt-3">✍️ نویسندگان</h6>
                <a href="@BuildUrl(1, null, "")" class="filter-link @(string.IsNullOrEmpty(filter.AuthorSlug) ? "active" : "")">همه نویسندگان</a>
                @foreach (var author in authors)
                {
                    <a href="@BuildUrl(1, null, author.Slug)" class="filter-link @(filter.AuthorSlug == author.Slug ? "active" : "")">
                        @author.FullName
                    </a>
                }
            }
        </div>
    </div>

    <!-- ── Main Content ── -->
    <div class="col-md-9 col-lg-10">

        <!-- Header row -->
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="section-title mb-0">
                @if (!string.IsNullOrEmpty(filter.SearchTerm))
                {
                    <span>نتایج جستجو برای «@filter.SearchTerm»</span>
                }
                else if (!string.IsNullOrEmpty(filter.CategorySlug))
                {
                    var selectedCat = categories.FirstOrDefault(c => c.Slug == filter.CategorySlug);
                    <span>دسته: @(selectedCat?.Name ?? filter.CategorySlug)</span>
                }
                else
                {
                    <span>همه کتاب‌ها</span>
                }
            </div>
            <span class="text-muted small">@Model.TotalCount کتاب یافت شد</span>
        </div>

        @if (!Model.Items.Any())
        {
            <div class="text-center py-5 text-muted">
                <div style="font-size:4rem">📭</div>
                <p class="mt-2">کتابی با این مشخصات یافت نشد.</p>
                <a href="/Books" class="btn btn-outline-primary btn-sm">نمایش همه کتاب‌ها</a>
            </div>
        }
        else
        {
            <!-- Grid -->
            <div class="row g-3">
                @foreach (var book in Model.Items)
                {
                    <div class="col-sm-6 col-md-4 col-xl-3">
                        <div class="book-card">
                            <div class="cover-wrap">
                                @if (!string.IsNullOrEmpty(book.CoverImagePath))
                                {
                                    <img src="@book.CoverImagePath" alt="@book.Title" />
                                }
                                else
                                {
                                    <span class="cover-placeholder">📖</span>
                                }
                            </div>
                            <div class="card-body">
                                <div class="book-title">@book.Title</div>
                                @if (book.AuthorNames.Any())
                                {
                                    <div class="book-author">@string.Join("، ", book.AuthorNames)</div>
                                }
                                <div class="book-meta">
                                    <span>@book.PublishedYear</span>
                                    <span>@book.PageCount ص</span>
                                    <span class="badge-cat">@book.CategoryName</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="@(book.IsFree ? "badge-free" : "badge-paid")">
                                        @(book.IsFree ? "رایگان" : "غیررایگان")
                                    </span>
                                    <a asp-controller="Books" asp-action="Details"
                                       asp-route-slug="@book.Slug"
                                       class="btn btn-sm btn-outline-primary" style="font-size:.78rem; padding:3px 10px;">
                                        مشاهده
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <nav class="mt-4">
                    <ul class="pagination justify-content-center">
                        @if (Model.HasPreviousPage)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@BuildUrl(Model.Page - 1)">«</a>
                            </li>
                        }
                        @for (int i = Math.Max(1, Model.Page - 2); i <= Math.Min(Model.TotalPages, Model.Page + 2); i++)
                        {
                            <li class="page-item @(i == Model.Page ? "active" : "")">
                                <a class="page-link" href="@BuildUrl(i)">@i</a>
                            </li>
                        }
                        @if (Model.HasNextPage)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@BuildUrl(Model.Page + 1)">»</a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        }
    </div>
</div>
