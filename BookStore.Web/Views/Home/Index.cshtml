@{
    ViewData["Title"] = "کتابخانه دیجیتال";
}

<!-- Hero -->
<div style="background:linear-gradient(135deg,#2c5f8a 0%,#1a3d5c 100%); border-radius:16px;
            padding:3rem 2rem; color:#fff; text-align:center; margin-bottom:3rem;">
    <h1 style="font-size:2rem; font-weight:800; margin-bottom:.75rem;"><i class="fa-solid fa-book-open me-2"></i> کتابخانه دیجیتال</h1>
    <p style="font-size:1.05rem; opacity:.9; margin-bottom:1.5rem;">
        هزاران کتاب ارزشمند — رایگان در دسترس شما
    </p>
    <form asp-controller="Books" asp-action="Index" method="get"
          style="max-width:480px; margin:0 auto; display:flex; gap:8px;">
        <input type="text" name="SearchTerm" placeholder="عنوان یا نویسنده را جستجو کنید..."
               class="form-control"
               style="border-radius:20px; border:none; padding:.6rem 1.2rem;" />
        <button type="submit" class="btn"
                style="background:#e8a020; color:#fff; border-radius:20px; padding:.6rem 1.5rem; white-space:nowrap;">
            جستجو
        </button>
    </form>
</div>

<!-- Quick links to all books -->
<div class="text-center mb-4">
    <a asp-controller="Books" asp-action="Index" class="btn btn-outline-primary px-4">
        مشاهده همه کتاب‌ها <i class="fa-solid fa-arrow-right me-1"></i>
    </a>
</div>
